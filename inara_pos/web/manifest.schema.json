{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chiyagadi.local/schemas/web-manifest-permissive.json",
  "title": "ChiyaGadi web app manifest (permissive)",
  "description": "W3C Web App Manifest core fields plus additionalProperties: true. User agents ignore unknown members (see W3C); this schema avoids editor warnings for experimental keys (file_handlers, share_target, iarc_rating_id, etc.).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "short_name": { "type": "string" },
    "lang": { "type": "string" },
    "dir": { "type": "string", "enum": ["ltr", "rtl", "auto"] },
    "start_url": { "type": "string" },
    "scope": { "type": "string" },
    "display": { "type": "string" },
    "display_override": { "type": "array", "items": { "type": "string" } },
    "background_color": { "type": "string" },
    "theme_color": { "type": "string" },
    "description": { "type": "string" },
    "orientation": { "type": "string" },
    "prefer_related_applications": { "type": "boolean" },
    "related_applications": { "type": "array" },
    "categories": { "type": "array", "items": { "type": "string" } },
    "screenshots": { "type": "array" },
    "shortcuts": { "type": "array" },
    "icons": { "type": "array" },
    "serviceworker": { "type": "object" },
    "iarc_rating_id": { "type": "string" },
    "file_handlers": { "type": "array" },
    "launch_handler": { "type": "object" },
    "protocol_handlers": { "type": "array" },
    "share_target": { "type": "object" },
    "widgets": { "type": "array" },
    "edge_side_panel": { "type": "object" },
    "note_taking": { "type": "object" },
    "scope_extensions": { "type": "array" }
  }
}
